# Variables
CC = gcc          # C Compiler
CFLAGS = -Wall -g # Compiler flags

all: userclean

userclean: userclean.c
	gcc $(CC) $(CFLAGS) userclean.c -o userclean

.PHONY: clean
clean:
	rm -f userclean
    
